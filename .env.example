# Wallet (base58 private key and public key)
PRIVATE_KEY=
PUBLIC_KEY=

# Solana RPC (Helius recommended)
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=YOUR_KEY

# Token Mints
NASDAQ_MINT=                    # Reward token mint address
TRACKED_TOKEN_MINT=             # Token whose holders receive rewards

# Optional
CHECK_INTERVAL_MINUTES=5
MIN_SOL_RESERVE=0.05
DISCORD_WEBHOOK_URL=
